# Database Configuration (PostgreSQL)
POSTGRES_USER=ctbms_prod
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=ctbms_prod

# Backend API Configuration
# Google Gemini API Key (Required for AI Analysis)
GEMINI_API_KEY=your_google_genai_api_key_here

# Frontend Configuration
# (Optional) If you enable client-side AI calls in the future
# VITE_GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# Market-data cutover compensation auto sweep
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_ENABLED=false
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_SCOPE=USER
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_USER_ID=system-auto-compensation
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_WINDOW_DAYS=7
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_LIMIT=20
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_DATASETS=SPOT_PRICE,FUTURES_QUOTE,MARKET_EVENT
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_MAX_CONCURRENCY=3
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_TIMEOUT_MS=30000
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_STOP_ON_FAILURE_COUNT=5
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_STOP_ON_FAILURE_RATE=0.8
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_MIN_PROCESSED=3
MARKET_DATA_CUTOVER_COMPENSATION_AUTORUN_IDEMPOTENCY_SLOT_MINUTES=10

# ── Delivery Channel Configuration ──────────────────────────────
# SMTP (for EMAIL delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com
API_BASE_URL=http://localhost:3000

# WeChat Work (企业微信 Webhook)
WECOM_DELIVERY_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# DingTalk (钉钉 Webhook)
DINGTALK_DELIVERY_WEBHOOK_URL=

# Feishu (飞书 Webhook)
FEISHU_DELIVERY_WEBHOOK_URL=

# Email fallback via webhook (optional, used when SMTP is not configured)
MAIL_DELIVERY_WEBHOOK_URL=
